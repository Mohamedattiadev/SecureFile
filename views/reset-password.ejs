<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 mt-5">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock text-primary fs-1"></i>
                    <h2 class="fw-bold mt-2">New Password</h2>
                    <p class="text-muted">Set a secure password for your account.</p>
                </div>

                <form action="/auth/reset-password" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="token" value="<%= token %>">
                    <div class="form-floating mb-3">
                        <input type="password" name="password" class="form-control" id="password"
                            placeholder="New Password" required minlength="8">
                        <label for="password">New Password (min 8 chars)</label>
                    </div>
                    <button class="btn btn-primary w-100 rounded-pill py-3" type="submit">
                        Set New Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>