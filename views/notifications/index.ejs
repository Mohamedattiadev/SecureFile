<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4">Notifications</h4>

                <% if (notifications.length===0) { %>
                    <div class="text-center py-5">
                        <i class="bi bi-bell-slash text-muted display-1"></i>
                        <p class="mt-3 text-muted">No new notifications</p>
                    </div>
                    <% } else { %>
                        <div class="list-group list-group-flush">
                            <% notifications.forEach(no=> { %>
                                <div
                                    class="list-group-item border-0 p-3 mb-2 rounded-4 <%= no.is_read ? 'bg-light opacity-75' : 'bg-primary-subtle border-start border-primary border-4' %>">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <p class="mb-0 <%= no.is_read ? '' : 'fw-bold' %>">
                                                <%= no.message %>
                                            </p>
                                            <small class="text-muted">
                                                <%= new Date(no.created_at).toLocaleString() %>
                                            </small>
                                        </div>
                                        <% if (!no.is_read) { %>
                                            <form action="/notifications/mark-read/<%= no.id %>" method="POST">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button class="btn btn-sm btn-link text-primary p-0">Mark as
                                                    read</button>
                                            </form>
                                            <% } %>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
</div>