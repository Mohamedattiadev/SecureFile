<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
            <div class="card-body">
                <h6 class="text-white-50">Total Users</h6>
                <h2 class="fw-bold mb-0">
                    <%= stats.userCount %>
                </h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-info text-white">
            <div class="card-body">
                <h6 class="text-white-50">Total Files</h6>
                <h2 class="fw-bold mb-0">
                    <%= stats.fileCount %>
                </h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-danger text-white">
            <div class="card-body">
                <h6 class="text-white-50">Failed Logins</h6>
                <h2 class="fw-bold mb-0">
                    <%= stats.failedLogins %>
                </h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-success text-white">
            <div class="card-body">
                <h6 class="text-white-50">Encrypted Data</h6>
                <h2 class="fw-bold mb-0">
                    <%= stats.encryptedFiles %>
                </h2>
                <small class="opacity-75">Files at rest</small>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0"><i class="bi bi-people-fill me-2"></i> User Management</h5>
            <div class="d-flex gap-2">
                <a href="/admin/backup" class="btn btn-outline-primary btn-sm rounded-pill">
                    <i class="bi bi-download me-1"></i> Data Backup
                </a>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u=> { %>
                        <tr>
                            <td>
                                <%= u.username %>
                            </td>
                            <td>
                                <%= u.email %>
                            </td>
                            <td>
                                <span class="badge <%= u.is_verified ? 'bg-success' : 'bg-warning' %> rounded-pill">
                                    <%= u.is_verified ? 'Verified' : 'Pending' %>
                                </span>
                            </td>
                            <td><span class="badge bg-secondary rounded-pill text-uppercase">
                                    <%= u.role %>
                                </span></td>
                            <td>
                                <form action="/admin/delete-user/<%= u.id %>" method="POST" class="d-inline"
                                    onsubmit="return confirm('Delete user?');">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="btn btn-sm btn-outline-danger border-0"><i
                                            class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-4"><i class="bi bi-journal-text me-2"></i> System Audit Logs</h5>
        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
            <table class="table table-sm small align-middle">
                <thead class="bg-light sticky-top">
                    <tr>
                        <th>Action</th>
                        <th>User ID</th>
                        <th>Details</th>
                        <th>Time</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    <% logs.forEach(log=> { %>
                        <tr class="<%= log.action.includes('FAIL') ? 'table-danger' : '' %>">
                            <td><span class="fw-bold text-uppercase">
                                    <%= log.action %>
                                </span></td>
                            <td>
                                <%= log.user_id || 'Guest' %>
                            </td>
                            <td>
                                <%= log.details || '-' %>
                            </td>
                            <td class="text-muted">
                                <%= new Date(log.timestamp).toLocaleString() %>
                            </td>
                            <td class="font-monospace">
                                <%= log.ip_address %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>