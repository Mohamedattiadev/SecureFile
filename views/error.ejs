<div class="d-flex align-items-center justify-content-center vh-100">
    <div class="text-center">
        <h1 class="display-1 fw-bold text-danger">
            <%= error && error.status ? error.status : 500 %>
        </h1>
        <p class="fs-3"> <span class="text-danger">Opps!</span> Something went wrong.</p>
        <p class="lead">
            <%= message %>
        </p>

        <% if (error && error.stack) { %>
            <div class="alert alert-warning text-start mt-4 overflow-auto rounded shadow-sm" style="max-height: 300px;">
                <pre class="mb-0"><code class="small"><%= error.stack %></code></pre>
            </div>
            <% } %>

                <a href="/" class="btn btn-primary rounded-pill px-4 mt-3 mt-lg-0"><i class="bi bi-house"></i> Go
                    Home</a>
    </div>
</div>