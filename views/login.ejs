<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-3 mt-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-circle text-primary fs-1"></i>
                    <h2 class="fw-bold mt-2">Sign In</h2>
                    <p class="text-muted">Access your SecureFile dashboard</p>
                </div>

                <form action="/auth/login" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="username" name="username" placeholder="Username"
                            value="<%= formData ? formData.username : '' %>" required autocomplete="username">
                        <label for="username">Username</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" class="form-control" id="password" name="password" placeholder="Password"
                            required autocomplete="current-password">
                        <label for="password">Password</label>
                    </div>

                    <button class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm mb-3" type="submit">Log
                        In</button>

                    <div class="text-center text-muted small">
                        Don't have an account? <a href="/auth/register" class="text-decoration-none">Register here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>