<div class="row justify-content-center h-100">
    <div class="col-md-9 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 d-flex flex-column" style="height: 75vh;">
            <!-- Header -->
            <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                <a href="/messages" class="text-muted me-3"><i class="bi bi-arrow-left fs-5"></i></a>
                <img src="<%= contact.avatar_path || 'https://ui-avatars.com/api/?name='+contact.username %>"
                    class="rounded-circle me-3" width="40" height="40">
                <h6 class="mb-0 fw-bold">
                    <%= contact.username %>
                </h6>
            </div>

            <!-- Messages List -->
            <div class="card-body p-4 flex-grow-1 overflow-auto" id="chatWindow">
                <% messages.forEach(m=> { %>
                    <div class="d-flex mb-4 <%= m.sender_id === user ? 'justify-content-end' : '' %>">
                        <div class="p-3 rounded-4 shadow-sm <%= m.sender_id === user ? 'bg-primary text-white ms-5' : 'bg-light text-dark me-5' %>"
                            style="max-width: 75%;">
                            <% if (m.is_encrypted) { %>
                                <small class="d-block mb-1 opacity-75"><i class="bi bi-shield-lock-fill"></i>
                                    Encrypted</small>
                                <% } %>
                                    <p class="mb-0">
                                        <%= m.content %>
                                    </p>
                                    <small class="d-block mt-1 opacity-50 pe-none" style="font-size: 0.7rem;">
                                        <%= new Date(m.created_at).toLocaleTimeString([], {hour: '2-digit' ,
                                            minute:'2-digit'}) %>
                                    </small>
                        </div>
                    </div>
                    <% }) %>
            </div>

            <!-- Footer -->
            <div class="card-footer bg-white border-0 p-3">
                <form id="messageForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" id="csrfToken">
                    <input type="hidden" name="receiverId" value="<%= contactId %>" id="receiverId">
                    <div class="input-group">
                        <button class="btn btn-outline-secondary border-end-0" type="button" data-bs-toggle="modal"
                            data-bs-target="#shareFileModal">
                            <i class="bi bi-paperclip"></i>
                        </button>
                        <div class="input-group-text bg-white border-start-0 border-end-0">
                            <input class="form-check-input mt-0" type="checkbox" name="encrypt" id="encryptCheck"
                                checked>
                            <label for="encryptCheck" class="small ms-2 text-muted pe-none"><i
                                    class="bi bi-shield-lock"></i></label>
                        </div>
                        <input type="text" name="content" id="messageInput" class="form-control border-start-0 py-2"
                            placeholder="Type a message..." required autocomplete="off">
                        <button class="btn btn-primary px-4" type="submit"><i class="bi bi-send-fill"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Share File Modal -->
<div class="modal fade" id="shareFileModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-body p-4">
                <h6 class="fw-bold mb-3">Share Your File</h6>
                <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                    <% if (myFiles && myFiles.length> 0) { %>
                        <% myFiles.forEach(f=> { %>
                            <button type="button" class="list-group-item list-group-item-action small py-2"
                                onclick="shareExistingFile('<%= f.id %>')">
                                <i class="bi bi-file-earmark me-2"></i>
                                <%= f.original_name %>
                            </button>
                            <% }) %>
                                <% } else { %>
                                    <p class="text-muted small">No files available to share.</p>
                                    <% } %>
                </div>
                <button class="btn btn-light w-100 rounded-pill mt-3 btn-sm" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<script>
    const chat = document.getElementById('chatWindow');
    const messageForm = document.getElementById('messageForm');
    const messageInput = document.getElementById('messageInput');
    const receiverId = document.getElementById('receiverId').value;
    const csrfToken = document.getElementById('csrfToken').value;

    chat.scrollTop = chat.scrollHeight;

    async function fetchMessages() {
        try {
            const res = await fetch(`/messages/${receiverId}/api`);
            const data = await res.json();
            if (data.messages) {
                renderMessages(data.messages, data.myId);
            }
        } catch (err) { console.error(err); }
    }

    function renderMessages(messages, myId) {
        const currentCount = chat.querySelectorAll('.d-flex').length;
        if (messages.length === currentCount) return;

        chat.innerHTML = messages.map(m => {
            const isMe = m.sender_id === myId;
            let content = m.content;
            if (m.attachment_file_id) {
                content = `<div class="p-2 border rounded bg-white-50 mt-1">
                                <i class="bi bi-file-earmark-check text-success me-1"></i>
                                <a href="/files/download/${m.attachment_file_id}" class="${isMe ? 'text-white' : 'text-primary'} fw-bold text-decoration-none">
                                    ${m.content}
                                </a>
                           </div>`;
            }
            return `
            <div class="d-flex mb-4 ${isMe ? 'justify-content-end' : ''}">
                <div class="p-3 rounded-4 shadow-sm ${isMe ? 'bg-primary text-white ms-5' : 'bg-light text-dark me-5'}" style="max-width: 75%;">
                    ${m.is_encrypted ? '<small class="d-block mb-1 opacity-75"><i class="bi bi-shield-lock-fill"></i> Encrypted</small>' : ''}
                    <div class="mb-0">${content}</div>
                    <small class="d-block mt-1 opacity-50 pe-none" style="font-size: 0.7rem;">
                        ${new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </small>
                </div>
            </div>
        `}).join('');
        chat.scrollTop = chat.scrollHeight;
    }

    messageForm.onsubmit = async (e) => {
        e.preventDefault();
        const content = messageInput.value;
        const encrypt = document.getElementById('encryptCheck').checked;

        messageInput.value = '';

        await fetch('/messages/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
            body: JSON.stringify({ receiverId, content, encrypt, _csrf: csrfToken })
        });
        fetchMessages();
    };

    async function shareExistingFile(fileId) {
        const modal = bootstrap.Modal.getInstance(document.getElementById('shareFileModal'));
        modal.hide();

        await fetch('/messages/share-file', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
            body: JSON.stringify({ receiverId, fileId, _csrf: csrfToken })
        });
        fetchMessages();
    }

    setInterval(fetchMessages, 3000); 
</script>