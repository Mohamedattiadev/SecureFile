PORT=3000
NODE_ENV=development
DB_FILE=database.sqlite
SESSION_SECRET=your_random_secret_here_at_least_32_chars
ENCRYPTION_KEY=your_32_byte_hex_key_here_!!!!!!!!!!!!!!!!

# Mailer Config (SMTP)
# To use Gmail, you must generate an "App Password" (do NOT use your normal email password):
# 1. Go to your Google Account -> Security -> 2-Step Verification
# 2. Scroll to the bottom and click "App Passwords"
# 3. Generate a new password for "SecureFile App" and paste the 16-character code below
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password
MAIL_FROM="SecureFile" <your_email@gmail.com>

# App URL (For links in emails)
APP_URL=http://localhost:3000
