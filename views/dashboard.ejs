<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="h3 mb-0 text-gray-800"><i class="bi bi-speedometer2 text-primary me-2"></i> Dashboard</h2>
    </div>
</div>

<div class="row">
    <!-- Upload Form Card -->
    <div class="col-xl-4 col-md-5 mb-4">
        <div class="card shadow-sm border-0 h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center mb-3">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Upload Document
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-cloud-arrow-up fs-2 text-muted"></i>
                    </div>
                </div>

                <p class="small text-muted mb-4">Allowed types: PDF, PNG, JPG, TXT (Max 5MB)</p>

                <form action="/files/upload?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input class="form-control" type="file" id="document" name="document" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 shadow-sm"><i class="bi bi-upload"></i> Upload
                        File</button>
                </form>

            </div>
        </div>
    </div>

    <!-- Files Table Card -->
    <div class="col-xl-8 col-md-7 mb-4">
        <div class="card shadow-sm border-0 h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center mb-4">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Your Files
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-folder fs-2 text-muted"></i>
                    </div>
                </div>

                <% if (files && files.length> 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Filename</th>
                                    <th>Uploaded</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% files.forEach(function(file) { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-file-earmark-text text-primary me-2"></i>
                                                <%= file.original_name %>
                                            </div>
                                        </td>
                                        <td class="text-muted small">
                                            <%= new Date(file.upload_date).toLocaleString() %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/files/download/<%= file.id %>"
                                                class="btn btn-sm btn-outline-primary" title="Download">
                                                <i class="bi bi-download"></i>
                                            </a>
                                            <form action="/files/delete/<%= file.id %>" method="POST"
                                                class="d-inline-block">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Delete"
                                                    onclick="return confirm('Are you sure you want to delete this file?');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="bi bi-folder-x text-muted" style="font-size: 3rem;"></i>
                            <p class="mt-3 text-muted">You haven't uploaded any files yet. Start by uploading a document
                                from the panel.</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
</div>