<div class="row g-4">
    <!-- Sidebar: Upload & Actions -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-cloud-arrow-up me-2 text-primary"></i> Upload Security</h5>
                <form action="/files/upload?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Select File</label>
                        <input class="form-control" type="file" name="document" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Encryption & Expiry</label>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="encrypt" id="encryptSwitch" checked>
                            <label class="form-check-label small" for="encryptSwitch">AES-256 Encryption at Rest</label>
                        </div>
                        <select class="form-select form-select-sm mb-2" name="expirationHours" id="expirySelect"
                            onchange="toggleCustomExpiry()">
                            <option value="">No expiration</option>
                            <option value="1">Expire in 1 hour</option>
                            <option value="24">Expire in 1 day</option>
                            <option value="168">Expire in 1 week</option>
                            <option value="720">Expire in 1 month</option>
                            <option value="2160">Expire in 3 months</option>
                            <option value="custom">Custom amount...</option>
                        </select>
                        <div class="input-group input-group-sm mt-2 d-none" id="customExpiryGroup">
                            <input type="number" name="customAmount" id="customAmount" class="form-control"
                                placeholder="Amount (e.g. 5)" min="1">
                            <select name="customUnit" class="form-select">
                                <option value="minutes">Minutes</option>
                                <option value="hours" selected>Hours</option>
                                <option value="days">Days</option>
                                <option value="months">Months</option>
                                <option value="years">Years</option>
                            </select>
                        </div>
                    </div>

                    <% if (typeof currentFolder !=='undefined' ) { %>
                        <input type="hidden" name="folderId" value="<%= currentFolder.id %>">
                        <% } %>

                            <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm py-2">
                                <i class="bi bi-shield-lock me-1"></i> Secure Upload
                            </button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-center">
                <h6 class="fw-bold mb-3 text-start">Quick Actions</h6>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-warning rounded-pill btn-sm" data-bs-toggle="modal"
                        data-bs-target="#newFolderModal">
                        <i class="bi bi-folder-plus me-1"></i> New Folder
                    </button>
                    <a href="/share/shared-with-me" class="btn btn-outline-info rounded-pill btn-sm">
                        <i class="bi bi-people me-1"></i> Shared With Me
                    </a>
                    <% if (typeof currentFolder !=='undefined' ) { %>
                        <a href="/folders/download/<%= currentFolder.id %>"
                            class="btn btn-outline-primary rounded-pill btn-sm mt-2">
                            <i class="bi bi-file-zip me-1"></i> Download Folder
                        </a>
                        <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Section: Folders & Files -->
    <div class="col-lg-8">
        <% if (typeof currentFolder !=='undefined' ) { %>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-4 p-3 bg-white rounded-4 shadow-sm">
                    <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none"><i
                                class="bi bi-house-door"></i> Dashboard</a></li>
                    <li class="breadcrumb-item active">
                        <%= currentFolder.name %>
                    </li>
                </ol>
            </nav>
            <% } %>

                <!-- User Search Section -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-3">
                        <form action="/messages/search" method="POST" class="d-flex gap-2">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i
                                        class="bi bi-person-search text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-start-0"
                                    placeholder="Search usernames to start secure chat..." required>
                            </div>
                            <button class="btn btn-primary btn-sm rounded-pill px-4" type="submit">Chat</button>
                        </form>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <!-- Folders List -->
                        <% if (folders && folders.length> 0) { %>
                            <div class="p-4 border-bottom">
                                <h6 class="text-muted small fw-bold text-uppercase mb-3">Folders</h6>
                                <div class="row g-3">
                                    <% folders.forEach(f=> { %>
                                        <div class="col-6 col-md-4 col-xl-3 position-relative group-hover-trigger">
                                            <button type="button" onclick="deleteFolder('<%= f.id %>', this)"
                                                class="btn btn-sm btn-link text-danger position-absolute pt-1 pe-2 top-0 end-0 opacity-75 hover-opacity-100"
                                                style="z-index: 10;" title="Delete Folder">
                                                <i class="bi bi-x-circle-fill fs-5"></i>
                                            </button>
                                            <a href="/folders/<%= f.id %>" class="text-decoration-none">
                                                <div
                                                    class="card border-0 bg-light-subtle shadow-none rounded-3 text-center py-3 hover-shadow transition pt-4">
                                                    <i class="bi bi-folder-fill text-warning fs-1"></i>
                                                    <div class="fw-bold text-dark mt-2 small text-truncate px-2">
                                                        <%= f.name %>
                                                    </div>
                                                </div>
                                            </a>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                            <% } %>

                                <!-- Files List -->
                                <div class="p-4">
                                    <h6 class="text-muted small fw-bold text-uppercase mb-3">Recent Files</h6>
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th class="border-0 rounded-start-4">Name</th>
                                                    <th class="border-0">Security</th>
                                                    <th class="border-0 text-end rounded-end-4">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% files.forEach(file=> { %>
                                                    <tr>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <div class="bg-primary-subtle p-2 rounded-3 me-3">
                                                                    <i
                                                                        class="bi bi-file-earmark-lock text-primary fs-5"></i>
                                                                </div>
                                                                <div class="text-truncate" style="max-width: 250px;">
                                                                    <div class="fw-bold text-dark lh-sm">
                                                                        <%= file.original_name %>
                                                                    </div>
                                                                    <small class="text-muted"
                                                                        style="font-size: 0.7rem;">
                                                                        <%= new
                                                                            Date(file.upload_date).toLocaleDateString()
                                                                            %>
                                                                    </small>
                                                                    <% if (file.shared_with_names) { %>
                                                                        <span
                                                                            class="badge bg-info-subtle text-info border border-info-subtle ms-2 rounded-pill"
                                                                            style="font-size: 0.65rem;"
                                                                            data-bs-toggle="tooltip"
                                                                            title="Shared with: <%= file.shared_with_names %>">
                                                                            <i class="bi bi-people-fill"></i> Shared
                                                                        </span>
                                                                        <% } %>
                                                                            </small>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                <% if (file.is_encrypted) { %>
                                                                    <span
                                                                        class="badge bg-success-subtle text-success small rounded-pill">
                                                                        <i class="bi bi-shield-lock"></i> AES-256
                                                                    </span>
                                                                    <% } %>
                                                                        <% if (file.expires_at) { const remaining=new
                                                                            Date(file.expires_at) - new Date(); const
                                                                            days=Math.floor(remaining / (1000 * 60 * 60
                                                                            * 24)); const hours=Math.floor((remaining %
                                                                            (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                                                                            %>
                                                                            <span
                                                                                class="badge bg-warning-subtle text-warning small rounded-pill">
                                                                                <i class="bi bi-clock"></i>
                                                                                <%= days> 0 ? days + 'd ' : '' %><%=
                                                                                        hours> 0 || days === 0 ? hours +
                                                                                        'h' : '' %> left
                                                                            </span>
                                                                            <% } %>
                                                            </div>
                                                        </td>
                                                        <td class="text-end">
                                                            <div class="dropdown">
                                                                <button
                                                                    class="btn btn-sm btn-light border rounded-pill px-3"
                                                                    data-bs-toggle="dropdown"
                                                                    data-bs-boundary="viewport">
                                                                    <i class="bi bi-three-dots-vertical"></i>
                                                                </button>
                                                                <ul
                                                                    class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                                                    <li><a class="dropdown-item py-2"
                                                                            href="/files/download/<%= file.id %>"><i
                                                                                class="bi bi-download me-2 text-primary"></i>
                                                                            Download</a></li>
                                                                    <li>
                                                                        <form
                                                                            action="/files/generate-link/<%= file.id %>"
                                                                            method="POST" class="d-inline">
                                                                            <input type="hidden" name="_csrf"
                                                                                value="<%= csrfToken %>">
                                                                            <button class="dropdown-item py-2"
                                                                                type="submit">
                                                                                <i
                                                                                    class="bi bi-link-45deg me-2 text-info"></i>
                                                                                Get Signed Link
                                                                            </button>
                                                                        </form>
                                                                    </li>
                                                                    <li><button class="dropdown-item py-2"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#shareModal"
                                                                            onclick="setShareFile('<%= file.id %>')"><i
                                                                                class="bi bi-share me-2 text-success"></i>
                                                                            Share</button></li>
                                                                    <li>
                                                                        <hr class="dropdown-divider">
                                                                    </li>
                                                                    <li>
                                                                        <form action="/files/delete/<%= file.id %>"
                                                                            method="POST"
                                                                            onsubmit="return confirm('Delete permanently?');">
                                                                            <input type="hidden" name="_csrf"
                                                                                value="<%= csrfToken %>">
                                                                            <button
                                                                                class="dropdown-item py-2 text-danger"><i
                                                                                    class="bi bi-trash me-2"></i>
                                                                                Delete</button>
                                                                        </form>
                                                                    </li>
                                                                </ul>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% if (files.length===0 && (!folders || folders.length===0)) {
                                                            %>
                                                            <tr>
                                                                <td colspan="3" class="text-center py-5">
                                                                    <i
                                                                        class="bi bi-inbox text-muted display-1 opacity-25"></i>
                                                                    <p class="mt-3 text-muted">No files or folders
                                                                        found. Start by uploading one!</p>
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                    </div>
                </div>

    </div>
</div>
</div>
</div>

<!-- Folder Modal -->
<div class="modal fade" id="newFolderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-body p-4">
                <h5 class="fw-bold mb-3">Create Folder</h5>
                <form action="/folders/create" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <% if (typeof currentFolder !=='undefined' ) { %>
                        <input type="hidden" name="parentId" value="<%= currentFolder.id %>">
                        <% } %>
                            <input type="text" name="name" class="form-control mb-3" placeholder="Folder Name" required>
                            <button class="btn btn-primary w-100 rounded-pill">Create</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-body p-4">
                <h5 class="fw-bold mb-3">Share Securely</h5>
                <form action="/share/file" method="POST" id="shareForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="fileId" id="shareFileId">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Target Username</label>
                        <input type="text" name="username" id="shareUsername" class="form-control"
                            placeholder="Enter username..." required autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <select name="permission" class="form-select">
                            <option value="view">Can View</option>
                            <option value="download">Can Download</option>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100 rounded-pill">Share File</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    <div id="copyToast" class="toast align-items-center text-bg-success border-0 shadow" role="alert"
        aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-bold">
                <i class="bi bi-check-circle me-2"></i> Link copied to clipboard!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                aria-label="Close"></button>
        </div>
    </div>

    <div id="deleteErrorToast" class="toast align-items-center text-bg-danger border-0 shadow" role="alert"
        aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-bold" id="deleteErrorToastBody">
                <i class="bi bi-exclamation-circle me-2"></i> Failed to delete folder.
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Signed Link Modal -->
<div class="modal fade" id="signedLinkModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold mb-0 text-success"><i class="bi bi-link-45deg"></i> Secure Link Generated</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="small text-muted mb-2">This link will expire in 15 minutes. Anyone with the link can download
                    the file.</p>
                <div class="input-group">
                    <input type="text" id="signedLinkInput" class="form-control bg-light" readonly>
                    <button class="btn btn-outline-primary" type="button" onclick="copySignedLink()"><i
                            class="bi bi-clipboard"></i> Copy</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Folder Modal -->
<div class="modal fade" id="deleteFolderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold text-danger mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Delete Folder</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="mb-4 text-muted">This will permanently delete the folder and ALL its contents. This action
                    cannot be undone.</p>
                <div class="d-flex justify-content-center gap-3">
                    <button type="button" class="btn btn-light rounded-pill px-4 hover-shadow"
                        data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 shadow-sm"
                        id="confirmDeleteFolderBtn">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    document.addEventListener('DOMContentLoaded', function () {
        <% if (locals.generatedLink && generatedLink) { %>
            const linkInput = document.getElementById('signedLinkInput');
            linkInput.value = '<%= generatedLink %>';
            const modal = new bootstrap.Modal(document.getElementById('signedLinkModal'));
            modal.show();
        <% } %>
    });

    function setShareFile(id) {
        document.getElementById('shareFileId').value = id;
        setTimeout(() => document.getElementById('shareUsername').focus(), 500);
        console.log("Setting share file ID to:", id);
    }

    function copySignedLink() {
        const copyText = document.getElementById("signedLinkInput");
        copyText.select();
        copyText.setSelectionRange(0, 99999);
        navigator.clipboard.writeText(copyText.value).then(() => {
            const toastEl = document.getElementById('copyToast');
            const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
            toast.show();
        }).catch(err => {
            console.error('Failed to copy text: ', err);
            alert("Failed to copy link. Please select and copy manually.");
        });
    }
    function toggleCustomExpiry() {
        const select = document.getElementById('expirySelect');
        const custom = document.getElementById('customExpiryGroup');
        const customAmount = document.getElementById('customAmount');
        if (select.value === 'custom') {
            custom.style.display = 'flex';
            custom.classList.remove('d-none');
            customAmount.required = true;
        } else {
            custom.style.display = 'none';
            customAmount.required = false;
        }
    }

    let pendingDeleteFolderId = null;
    let pendingDeleteFolderBtn = null;

    function deleteFolder(id, btnElement) {
        pendingDeleteFolderId = id;
        pendingDeleteFolderBtn = btnElement;
        const modal = new bootstrap.Modal(document.getElementById('deleteFolderModal'));
        modal.show();
    }

    function showErrorToast(msg) {
        document.getElementById('deleteErrorToastBody').innerHTML = '<i class="bi bi-exclamation-circle me-2"></i> ' + msg;
        const toastEl = document.getElementById('deleteErrorToast');
        const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
        toast.show();
    }

    document.addEventListener('DOMContentLoaded', function () {
        const confirmBtn = document.getElementById('confirmDeleteFolderBtn');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', function () {
                if (!pendingDeleteFolderId) return;
                const csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').content : '<%= csrfToken %>';

                // disable button
                const btn = this;
                const origText = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Deleting...';
                btn.disabled = true;

                fetch('/folders/delete/' + pendingDeleteFolderId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': csrfToken
                    },
                    body: JSON.stringify({ _csrf: csrfToken })
                })
                    .then(res => res.json())
                    .then(data => {
                        const modal = bootstrap.Modal.getInstance(document.getElementById('deleteFolderModal'));
                        if (modal) modal.hide();
                        btn.innerHTML = origText;
                        btn.disabled = false;

                        if (data.success) {
                            if (pendingDeleteFolderBtn) {
                                pendingDeleteFolderBtn.closest('.col-xl-3').remove();
                            } else {
                                // fallback if button lost context, reload dashboard
                                window.location.reload();
                            }
                        } else {
                            showErrorToast(data.message || 'Failed to delete folder');
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        const modal = bootstrap.Modal.getInstance(document.getElementById('deleteFolderModal'));
                        if (modal) modal.hide();
                        btn.innerHTML = origText;
                        btn.disabled = false;
                        showErrorToast('An error occurred deleting the folder.');
                    });
            });
        }
    });
</script>

<style>
    .transition {
        transition: all 0.2s ease-in-out;
    }

    .hover-shadow:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .1) !important;
    }
</style>