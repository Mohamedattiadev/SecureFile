<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Messages</h4>
                    <button class="btn btn-primary rounded-pill btn-sm" data-bs-toggle="modal"
                        data-bs-target="#newChatModal">
                        <i class="bi bi-plus-lg"></i> New Chat
                    </button>
                </div>

                <% if (contacts.length===0) { %>
                    <div class="text-center py-5">
                        <i class="bi bi-chat-dots-fill text-muted display-1"></i>
                        <p class="mt-3 text-muted">No conversations yet</p>
                    </div>
                    <% } else { %>
                        <div class="list-group list-group-flush">
                            <% contacts.forEach(contact=> { %>
                                <a href="/messages/<%= contact.id %>"
                                    class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                                    <img src="<%= contact.avatar_path || 'https://ui-avatars.com/api/?name='+contact.username %>"
                                        class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-0 fw-bold">
                                            <%= contact.username %>
                                        </h6>
                                        <small class="text-muted">Click to view chat history</small>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </a>
                                <% }) %>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
</div>

<!-- New Chat Modal -->
<div class="modal fade" id="newChatModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Start New Chat</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form action="/messages/search" method="POST" id="searchUserForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="input-group">
                        <input type="text" id="targetUsername" name="username" class="form-control"
                            placeholder="Enter username..." required>
                        <button class="btn btn-primary" type="submit">Chat</button>
                    </div>
                    <div id="searchResults" class="mt-3"></div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('searchUserForm').onsubmit = function (e) {
        // For simplicity, we'll just redirect to a predicted route if it exists, or handle via a small endpoint.
        // Let's keep it simple for now as per instructions.
    };
</script>