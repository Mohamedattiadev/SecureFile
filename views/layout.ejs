<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'SecureFile' %>
    </title>
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        /* Fix for dropdowns being cut off in table-responsive */
        .table-responsive {
            overflow: visible !important;
        }

        @media (max-width: 991.98px) {
            .table-responsive {
                overflow-x: auto !important;
            }
        }

        .dropdown-menu {
            z-index: 1050;
            /* Ensure it's above other elements */
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-shield-lock-fill"></i> SecureFile
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/share/shared-with-me"><i class="bi bi-share"></i> Shared</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/messages"><i class="bi bi-chat-dots"></i> Messages</a>
                        </li>
                        <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (user) { %>
                        <li class="nav-item dropdown px-2">
                            <a class="nav-link" href="#" id="notificationDropdown" role="button"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <i class="bi bi-bell"></i>
                                <% const unreadCount=notifications.filter(n=> !n.is_read).length; %>
                                    <% if (unreadCount> 0) { %>
                                        <span
                                            class="position-absolute top-25 start-75 translate-middle badge rounded-pill bg-danger"
                                            style="font-size: 0.55rem;">
                                            <%= unreadCount %>
                                        </span>
                                        <% } %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-0"
                                style="width: 320px; max-height: 400px; overflow-y: auto;">
                                <li class="p-3 border-bottom bg-light fw-bold text-muted small text-uppercase">
                                    Notifications</li>
                                <% if (notifications.length===0) { %>
                                    <li class="p-4 text-center text-muted small">No recent notifications</li>
                                    <% } else { %>
                                        <% notifications.forEach(n=> { %>
                                            <li
                                                class="border-bottom p-3 <%= n.is_read ? 'bg-white' : 'bg-primary-subtle' %>">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="small text-wrap pe-2 text-dark"
                                                        style="font-size: 0.85rem;">
                                                        <%= n.message %>
                                                    </div>
                                                    <% if (!n.is_read) { %>
                                                        <button onclick="markNotificationRead('<%= n.id %>', this)"
                                                            class="btn btn-sm text-primary p-0 m-0 border-0 bg-transparent"
                                                            title="Mark as read">
                                                            <i class="bi bi-check2-circle fs-5"></i>
                                                        </button>
                                                        <% } %>
                                                </div>
                                                <div class="text-muted mt-1" style="font-size: 0.7rem;">
                                                    <%= new Date(n.created_at).toLocaleString() %>
                                                </div>
                                            </li>
                                            <% }) %>
                                                <li><a href="/notifications"
                                                        class="dropdown-item text-center text-primary fw-bold small py-3 bg-light">View
                                                        All Notifications</a></li>
                                                <% } %>
                            </ul>
                        </li>
                        <li class="nav-item dropdown px-2">
                            <a class="nav-link dropdown-toggle" href="#" id="profileDropdown" role="button"
                                data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <%= username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person"></i> Profile</a>
                                </li>
                                <% if (role==='admin' ) { %>
                                    <li><a class="dropdown-item text-primary" href="/admin"><i
                                                class="bi bi-shield-lock"></i> Admin Panel</a></li>
                                    <% } %>
                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>
                                        <li><a class="dropdown-item text-danger" href="/auth/logout"><i
                                                    class="bi bi-box-arrow-right"></i> Logout</a></li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/auth/login"><i class="bi bi-box-arrow-in-right"></i>
                                    Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/auth/register"><i class="bi bi-person-plus-fill"></i>
                                    Register</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container py-4 flex-grow-1">
        <% if (typeof success_msg !=='undefined' && success_msg && success_msg.length> 0) { %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill flex-shrink-0 me-2"></i>
                <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <% } %>

                <% if (typeof error_msg !=='undefined' && error_msg && error_msg.length> 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                        <%= error_msg %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    <% } %>

                        <% if (typeof error !=='undefined' && error && error.length> 0) { %>
                            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                                <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                                <%= error %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"
                                        aria-label="Close"></button>
                            </div>
                            <% } %>

                                <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-white text-center text-muted py-3 border-top mt-auto">
        <div class="container">
            <small>&copy; <%= new Date().getFullYear() %> SecureFile. Built with Secure defaults.</small>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function markNotificationRead(id, btnElement) {
            const csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').content : '<%= csrfToken %>';
            fetch('/notifications/mark-read/' + id, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'CSRF-Token': csrfToken
                },
                body: JSON.stringify({ _csrf: csrfToken })
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const li = btnElement.closest('li');
                        li.classList.remove('bg-primary-subtle');
                        li.classList.add('bg-white');
                        btnElement.remove();
                        // Optionally update the badge count
                        const badge = document.querySelector('#notificationDropdown .badge');
                        if (badge) {
                            let count = parseInt(badge.textContent) - 1;
                            if (count > 0) badge.textContent = count;
                            else badge.remove();
                        }
                    }
                })
                .catch(err => console.error(err));
        }
    </script>
</body>

</html>