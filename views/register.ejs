<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-3 mt-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus text-primary fs-1"></i>
                    <h2 class="fw-bold mt-2">Create Account</h2>
                    <p class="text-muted">Start securing your files today</p>
                </div>

                <form action="/auth/register" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="username" name="username" placeholder="Username"
                            value="<%= formData ? formData.username : '' %>" required minlength="3">
                        <label for="username">Username (min 3 chars)</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com"
                            value="<%= formData ? formData.email : '' %>" required>
                        <label for="email">Email address</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" class="form-control" id="password" name="password" placeholder="Password"
                            required minlength="8">
                        <label for="password">Password (min 8 chars)</label>
                    </div>

                    <button class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm mb-3"
                        type="submit">Register</button>

                    <div class="text-center text-muted small">
                        Already have an account? <a href="/auth/login" class="text-decoration-none">Log in here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>